---
// Ink-blot — a rough SVG blot in one of the page margins. Position,
// rotation, and opacity are driven by CSS custom properties set inline
// on .post-main (--ink-x, --ink-y, --ink-rot, --ink-opacity), themselves
// derived from the post slug's seed.
//
// Budget: single inline SVG, <10 path commands, <1KB of HTML.
---

<svg
  class="ink-blot"
  viewBox="0 0 100 100"
  aria-hidden="true"
  focusable="false"
  xmlns="http://www.w3.org/2000/svg"
>
  <defs>
    <filter id="ib-blur"><feGaussianBlur stdDeviation="0.6" /></filter>
  </defs>
  <g filter="url(#ib-blur)" fill="#1a0f07">
    <path d="M 50 14 Q 72 22 78 44 Q 88 62 68 78 Q 48 90 30 76 Q 12 58 22 38 Q 30 18 50 14 Z" />
    <circle cx="82" cy="40" r="3" opacity="0.55" />
    <circle cx="22" cy="78" r="2" opacity="0.45" />
    <path d="M 14 50 q 3 -6 9 -3" stroke="#1a0f07" stroke-width="1.4" fill="none" opacity="0.5" />
  </g>
</svg>

<style>
  .ink-blot {
    position: absolute;
    left: var(--ink-x, 50%);
    top: var(--ink-y, 50%);
    width: clamp(90px, 13vw, 150px);
    height: clamp(90px, 13vw, 150px);
    transform: translate(-50%, -50%) rotate(var(--ink-rot, 0deg));
    opacity: var(--ink-opacity, 0.14);
    pointer-events: none;
    mix-blend-mode: multiply;
    z-index: 0;
  }
</style>
