---
import type { Category } from '@lib/categories';
import PostHeader from './PostHeader.astro';
import PostMinimap from './PostMinimap';
import { getVariants, variantsToDataAttrs, type JournalVariants } from '@lib/variations';
import type { PersonalVariants } from '@lib/variations/personal';
import type { PoliticalVariants } from '@lib/variations/political';
import { hashSlug } from '@lib/seed';
import CoffeeRing from './variants/CoffeeRing.astro';
import InkBlot from './variants/InkBlot.astro';
import RoughUnderlines from './variants/RoughUnderlines';
import postViewEffectsScript from '../../scripts/post-view-effects.ts?url';

interface Props {
  title: string;
  category: Category;
  created: Date;
  tags: string[];
  slug: string;
}

const { title, category, created, tags, slug } = Astro.props;

const variants = getVariants(category, slug, created);
const dataAttrs = variantsToDataAttrs(variants);
const slugSeed = hashSlug(slug);

// Per-category inline CSS custom properties. Journal + personal need inline
// vars so pseudo-elements can be themed without an explosion of selectors.
let inlineStyle = '';
if (category === 'journal') {
  const j = variants as JournalVariants;
  inlineStyle = `--coffee-x:${j.coffeeRingX}%;--coffee-y:${j.coffeeRingY}%;--coffee-opacity:${j.coffeeRingOpacity};`;
} else if (category === 'personal') {
  const p = variants as PersonalVariants;
  inlineStyle =
    `--ink-x:${p.inkBlotX}%;--ink-y:${p.inkBlotY}%;--ink-rot:${p.inkBlotRot}deg;` +
    `--ink-opacity:${p.inkBlotOpacity};--marginalia-rot:${p.marginaliaRot}deg;`;
} else if (category === 'political') {
  const pol = variants as PoliticalVariants;
  inlineStyle = `--stamp-rot:${pol.stampRot}deg;--stamp-opacity:${pol.stampOpacity};`;
}
---

<main id="main-content">
  <article class="post-main" {...dataAttrs} style={inlineStyle}>
    <div class="post-hero" aria-hidden="true"></div>
    {category === 'journal' && <CoffeeRing />}
    {category === 'personal' && <InkBlot />}
    <PostHeader title={title} category={category} created={created} tags={tags} />
    <div class="post-body">
      <slot />
    </div>
    {category === 'personal' && (
      <RoughUnderlines
        client:visible
        roughness={(variants as PersonalVariants).underlineRoughness}
        seed={slugSeed}
      />
    )}
    <PostMinimap currentSlug={slug} client:visible />
  </article>
</main>

<style>
  .post-hero {
    view-transition-name: graph-node;
    position: fixed;
    inset: 0;
    background: var(--color-primary, #41d982);
    opacity: 0;
    pointer-events: none;
    z-index: -1;
  }

  :global(.post-minimap) {
    position: fixed;
    bottom: 1.1rem;
    right: 1.1rem;
    z-index: 4;
    width: 180px;
    height: 180px;
    border: 1px solid color-mix(in oklab, var(--color-primary) 30%, transparent);
    background: color-mix(in oklab, var(--color-bg) 85%, transparent);
    backdrop-filter: blur(6px);
    border-radius: 3px;
    transition: opacity 0.25s ease;
    opacity: 0.55;
  }
  :global(.post-minimap:hover),
  :global(.post-minimap:focus-within) {
    opacity: 1;
  }
  :global(.post-minimap a) {
    display: block;
    width: 100%;
    height: 100%;
  }
  :global(.post-minimap canvas) {
    display: block;
  }

  @media (max-width: 767px) {
    :global(.post-minimap) { display: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    :global(.post-minimap) { opacity: 0.75; }
  }
</style>

<script is:inline type="module" src={postViewEffectsScript}></script>
