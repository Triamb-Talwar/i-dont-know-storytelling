---
import type { Category } from '@lib/categories';
import PostHeader from './PostHeader.astro';

interface Props {
  title: string;
  category: Category;
  created: Date;
  tags: string[];
}

const { title, category, created, tags } = Astro.props;
---

<article class="post-main" id="main-content">
  <div class="post-hero" aria-hidden="true"></div>
  <PostHeader title={title} category={category} created={created} tags={tags} />
  <div class="post-body">
    <slot />
  </div>
</article>

<style>
  .post-hero {
    view-transition-name: graph-node;
    position: fixed;
    inset: 0;
    background: var(--color-primary, #41d982);
    opacity: 0;
    pointer-events: none;
    z-index: -1;
  }
</style>

<script>
  import { CATEGORY_CONFIG } from '@lib/categories';
  import type { Category } from '@lib/categories';

  const KEY_PREFIX = 'idks_visited_';
  const slug = window.location.pathname.replace(/^\/posts\//, '').replace(/\/$/, '');
  const visited = sessionStorage.getItem(KEY_PREFIX + slug);

  // Arriving rivers overlay — when we came here via a cross-category link,
  // the destination shows a translucent two-rivers gradient (origin → destination)
  // that lingers for ~2.5s then fades out. Different from the DURING-navigation wipe.
  (() => {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    const raw = sessionStorage.getItem('idks_origin');
    if (!raw) return;
    sessionStorage.removeItem('idks_origin');
    try {
      const origin = JSON.parse(raw) as {
        fromSlug: string;
        fromCat: Category;
        toSlug: string;
        toCat: Category;
        ts: number;
      };
      if (origin.toSlug !== slug) return;
      if (Date.now() - origin.ts > 8000) return;
      const from = CATEGORY_CONFIG[origin.fromCat]?.primary;
      const to = CATEGORY_CONFIG[origin.toCat]?.primary;
      if (!from || !to) return;

      // Two stacked "river" bands: diagonal streaks of origin color on one side
      // and destination color on the other, both translucent, pointer-events-none,
      // sitting above background art but below text via z-index:2 + low alpha.
      const overlay = document.createElement('div');
      overlay.className = 'arriving-rivers';
      overlay.style.cssText = `
        position: fixed; inset: 0; z-index: 2; pointer-events: none; opacity: 0;
        background:
          linear-gradient(115deg,
            ${from}55 0%,
            ${from}22 22%,
            transparent 42%,
            transparent 58%,
            ${to}22 78%,
            ${to}55 100%),
          radial-gradient(ellipse 60% 40% at 15% 30%, ${from}33, transparent 70%),
          radial-gradient(ellipse 60% 40% at 85% 70%, ${to}33, transparent 70%);
      `;
      document.body.appendChild(overlay);

      overlay.animate(
        [
          { opacity: 0 },
          { opacity: 1, offset: 0.12 },
          { opacity: 0.9, offset: 0.55 },
          { opacity: 0 },
        ],
        { duration: 2600, easing: 'cubic-bezier(0.4, 0, 0.2, 1)', fill: 'forwards' },
      ).onfinish = () => overlay.remove();
    } catch {}
  })();

  if (!visited && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    sessionStorage.setItem(KEY_PREFIX + slug, '1');
    const titleEl = document.querySelector('.post-title');
    if (titleEl) {
      const full = titleEl.textContent || '';
      titleEl.textContent = '';
      let i = 0;
      const tick = () => {
        if (i <= full.length) {
          titleEl.textContent = full.slice(0, i) + (i < full.length ? '▌' : '');
          i++;
          requestAnimationFrame(() => setTimeout(tick, 28 + Math.random() * 22));
        } else {
          titleEl.textContent = full;
        }
      };
      tick();
    }
  }
</script>
