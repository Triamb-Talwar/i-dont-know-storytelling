---
import type { Category } from '@lib/categories';
import PostHeader from './PostHeader.astro';
import PostMinimap from './PostMinimap';
import { getVariants, variantsToDataAttrs, type JournalVariants } from '@lib/variations';
import CoffeeRing from './variants/CoffeeRing.astro';

interface Props {
  title: string;
  category: Category;
  created: Date;
  tags: string[];
  slug: string;
}

const { title, category, created, tags, slug } = Astro.props;

const variants = getVariants(category, slug, created);
const dataAttrs = variantsToDataAttrs(variants);

// Per-category inline CSS custom properties. Journal variants expose coffee-ring
// position + opacity so the pseudo-element can be themed without extra selectors.
let inlineStyle = '';
if (category === 'journal') {
  const j = variants as JournalVariants;
  inlineStyle = `--coffee-x:${j.coffeeRingX}%;--coffee-y:${j.coffeeRingY}%;--coffee-opacity:${j.coffeeRingOpacity};`;
}
---

<article class="post-main" id="main-content" {...dataAttrs} style={inlineStyle}>
  <div class="post-hero" aria-hidden="true"></div>
  {category === 'journal' && <CoffeeRing />}
  <PostHeader title={title} category={category} created={created} tags={tags} />
  <div class="post-body">
    <slot />
  </div>
  <PostMinimap currentSlug={slug} client:visible />
</article>

<style>
  .post-hero {
    view-transition-name: graph-node;
    position: fixed;
    inset: 0;
    background: var(--color-primary, #41d982);
    opacity: 0;
    pointer-events: none;
    z-index: -1;
  }

  :global(.post-minimap) {
    position: fixed;
    bottom: 1.1rem;
    right: 1.1rem;
    z-index: 4;
    width: 180px;
    height: 180px;
    border: 1px solid color-mix(in oklab, var(--color-primary) 30%, transparent);
    background: color-mix(in oklab, var(--color-bg) 85%, transparent);
    backdrop-filter: blur(6px);
    border-radius: 3px;
    transition: opacity 0.25s ease;
    opacity: 0.55;
  }
  :global(.post-minimap:hover),
  :global(.post-minimap:focus-within) {
    opacity: 1;
  }
  :global(.post-minimap a) {
    display: block;
    width: 100%;
    height: 100%;
  }
  :global(.post-minimap canvas) {
    display: block;
  }

  @media (max-width: 767px) {
    :global(.post-minimap) { display: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    :global(.post-minimap) { opacity: 0.75; }
  }
</style>

<script>
  import { CATEGORY_CONFIG } from '@lib/categories';
  import type { Category } from '@lib/categories';

  const KEY_PREFIX = 'idks_visited_';
  const slug = window.location.pathname.replace(/^\/posts\//, '').replace(/\/$/, '');
  const visited = sessionStorage.getItem(KEY_PREFIX + slug);

  // Arriving rivers overlay — when we came here via a cross-category link,
  // the destination shows a translucent two-rivers gradient (origin → destination)
  // that lingers for ~2.5s then fades out. Different from the DURING-navigation wipe.
  (() => {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    const raw = sessionStorage.getItem('idks_origin');
    if (!raw) return;
    sessionStorage.removeItem('idks_origin');
    try {
      const origin = JSON.parse(raw) as {
        fromSlug: string;
        fromCat: Category;
        toSlug: string;
        toCat: Category;
        ts: number;
      };
      if (origin.toSlug !== slug) return;
      if (Date.now() - origin.ts > 8000) return;
      const from = CATEGORY_CONFIG[origin.fromCat]?.primary;
      const to = CATEGORY_CONFIG[origin.toCat]?.primary;
      if (!from || !to) return;

      // Two stacked "river" bands: diagonal streaks of origin color on one side
      // and destination color on the other, both translucent, pointer-events-none,
      // sitting above background art but below text via z-index:2 + low alpha.
      const overlay = document.createElement('div');
      overlay.className = 'arriving-rivers';
      overlay.style.cssText = `
        position: fixed; inset: 0; z-index: 2; pointer-events: none; opacity: 0;
        background:
          linear-gradient(115deg,
            ${from}55 0%,
            ${from}22 22%,
            transparent 42%,
            transparent 58%,
            ${to}22 78%,
            ${to}55 100%),
          radial-gradient(ellipse 60% 40% at 15% 30%, ${from}33, transparent 70%),
          radial-gradient(ellipse 60% 40% at 85% 70%, ${to}33, transparent 70%);
      `;
      document.body.appendChild(overlay);

      overlay.animate(
        [
          { opacity: 0 },
          { opacity: 1, offset: 0.12 },
          { opacity: 0.9, offset: 0.55 },
          { opacity: 0 },
        ],
        { duration: 2600, easing: 'cubic-bezier(0.4, 0, 0.2, 1)', fill: 'forwards' },
      ).onfinish = () => overlay.remove();
    } catch {}
  })();

  if (!visited && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    sessionStorage.setItem(KEY_PREFIX + slug, '1');
    const titleEl = document.querySelector('.post-title');
    if (titleEl) {
      const full = titleEl.textContent || '';
      titleEl.textContent = '';
      let i = 0;
      const tick = () => {
        if (i <= full.length) {
          titleEl.textContent = full.slice(0, i) + (i < full.length ? '▌' : '');
          i++;
          requestAnimationFrame(() => setTimeout(tick, 28 + Math.random() * 22));
        } else {
          titleEl.textContent = full;
          queueRipple();
        }
      };
      tick();
    } else {
      queueRipple();
    }
  }

  // You-are-here ripple — single concentric pulse from the post hero's center
  // using the current theme color. Plays once, right after the title finishes typing.
  function queueRipple() {
    const theme = document.documentElement.dataset.theme as Category | undefined;
    if (!theme) return;
    const color = CATEGORY_CONFIG[theme]?.primary;
    if (!color) return;

    const header = document.querySelector('.post-header') as HTMLElement | null;
    const rect = header?.getBoundingClientRect();
    const cx = rect ? rect.left + rect.width / 2 : window.innerWidth / 2;
    const cy = rect ? rect.top + 40 : window.innerHeight / 3;

    for (let i = 0; i < 2; i++) {
      const r = document.createElement('div');
      r.style.cssText = `
        position: fixed; left: ${cx}px; top: ${cy}px;
        width: 20px; height: 20px; margin: -10px 0 0 -10px;
        border: 2px solid ${color}; border-radius: 50%;
        pointer-events: none; z-index: 3; opacity: 0;
      `;
      document.body.appendChild(r);
      r.animate(
        [
          { transform: 'scale(0.4)', opacity: 0.9 },
          { transform: 'scale(14)', opacity: 0 },
        ],
        { duration: 1400 + i * 200, delay: i * 180, easing: 'cubic-bezier(0.22,1,0.36,1)', fill: 'forwards' },
      ).onfinish = () => r.remove();
    }
  }
</script>
