---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import { CATEGORIES, CATEGORY_CONFIG } from '@lib/categories';
import Graph from '@components/graph/Graph';

const posts = await getCollection('posts', ({ data }) => data.visibility === 'public');
posts.sort((a, b) => b.data.created.getTime() - a.data.created.getTime());

const byCategory = CATEGORIES.map((c) => ({
  id: c,
  label: CATEGORY_CONFIG[c].label,
  posts: posts.filter((p) => p.data.category === c),
}));
---

<BaseLayout title="i don't know storytelling">
  <main class="home">
    <header class="home-hdr" aria-hidden="true">
      <h1 class="home-title">i don't know storytelling</h1>
      <p class="home-sub">but i have stories to tell.</p>
      <p class="home-hint">drag · scroll · click a node</p>
    </header>

    <div class="graph-wrap">
      <Graph client:load />
    </div>

    {/* Parallel nav: crawlable + keyboard-reachable + mobile fallback */}
    <nav class="parallel-nav" id="main-content" aria-label="all posts">
      <h2>all posts</h2>
      {
        byCategory.map((cat) =>
          cat.posts.length === 0 ? null : (
            <section>
              <h3 style={`color:${CATEGORY_CONFIG[cat.id].primary}`}>{cat.label}</h3>
              <ul>
                {cat.posts.map((p) => (
                  <li>
                    <a href={`/posts/${p.data.slug}`}>{p.data.title}</a>
                  </li>
                ))}
              </ul>
            </section>
          ),
        )
      }
    </nav>
  </main>
</BaseLayout>

<style>
  .home {
    position: relative;
    min-height: 100dvh;
    background: #0a0a0b;
    color: #e5e7eb;
    font-family: ui-monospace, 'JetBrains Mono', 'SFMono-Regular', Menlo, monospace;
    overflow: hidden;
  }

  .home-hdr {
    position: fixed;
    top: clamp(1.2rem, 3vh, 2.4rem);
    left: clamp(1.2rem, 3vw, 2.4rem);
    z-index: 3;
    pointer-events: none;
    max-width: 28rem;
  }
  .home-title {
    font-size: clamp(1.1rem, 2vw, 1.6rem);
    font-weight: 500;
    letter-spacing: -0.01em;
    margin: 0;
    mix-blend-mode: difference;
    color: #f5f5f5;
  }
  .home-sub {
    color: #8b93a1;
    font-size: 0.85rem;
    margin: 0.15rem 0 0;
  }
  .home-hint {
    position: fixed;
    bottom: 1.2rem;
    right: 1.2rem;
    z-index: 3;
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #454b55;
    pointer-events: none;
  }

  .graph-wrap {
    position: absolute;
    inset: 0;
    z-index: 1;
  }
  .graph-wrap :global(.graph-root) {
    position: absolute;
    inset: 0;
  }
  .graph-wrap :global(.graph-canvas) {
    display: block;
    width: 100%;
    height: 100%;
    background:
      radial-gradient(ellipse at 20% 10%, #111319 0%, transparent 50%),
      radial-gradient(ellipse at 80% 90%, #0d1018 0%, transparent 55%),
      #07080a;
    touch-action: none;
  }
  .graph-wrap :global(.graph-loading) {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    color: #5a606b;
    font-size: 0.85rem;
    letter-spacing: 0.2em;
    text-transform: lowercase;
  }

  .parallel-nav {
    position: absolute;
    left: -99999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  @media (max-width: 767px) {
    .home {
      overflow: auto;
    }
    .home-hdr {
      position: static;
      padding: clamp(1.5rem, 5vh, 3rem) clamp(1rem, 5vw, 2rem) 0.5rem;
      max-width: none;
    }
    .home-title {
      font-size: clamp(1.3rem, 5vw, 1.9rem);
    }
    .home-hint {
      display: none;
    }
    .graph-wrap {
      display: none;
    }
    .parallel-nav {
      position: static;
      width: auto;
      height: auto;
      overflow: visible;
      padding: 1rem clamp(1rem, 5vw, 2rem) 4rem;
    }
    .parallel-nav h2 {
      font-size: 0.75rem;
      color: #5a606b;
      text-transform: uppercase;
      letter-spacing: 0.22em;
      margin: 1rem 0 1.5rem;
      padding-block-end: 0.8rem;
      border-block-end: 1px dashed #2a2e36;
      font-weight: 400;
    }
    .parallel-nav section {
      margin-block-end: 2rem;
    }
    .parallel-nav h3 {
      font-size: 0.72rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      margin: 0 0 0.75rem;
      font-weight: 500;
    }
    .parallel-nav ul {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      gap: 0.2rem;
    }
    .parallel-nav a {
      display: block;
      padding: 0.7rem 0;
      color: #e5e7eb;
      text-decoration: none;
      font-size: 1rem;
      border-block-end: 1px solid #1a1d23;
    }
    .parallel-nav a:hover {
      color: #fff;
    }
  }
</style>
