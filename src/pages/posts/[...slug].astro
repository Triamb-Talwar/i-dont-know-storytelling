---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import PostView from '@components/post/PostView.astro';
import Node from '@components/post/Node.astro';
import AsciiCanvas from '@components/post/AsciiCanvasIsland.astro';
import postInlineTransitionsScript from '../../scripts/post-inline-transitions.ts?url';

export const prerender = true;

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => data.visibility === 'public');
  return posts.map((post) => ({
    params: { slug: post.data.slug ?? post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const { title, category, created, tags } = post.data;
const slug = post.data.slug ?? post.id;

const allPosts = await getCollection('posts', ({ data }) => data.visibility === 'public');
const slugCategoryMap: Record<string, string> = {};
for (const p of allPosts) {
  slugCategoryMap[p.data.slug ?? p.id] = p.data.category;
}
---

<BaseLayout title={`${title} · i don't know storytelling`} theme={category}>
  <PostView title={title} category={category} created={created} tags={tags} slug={slug}>
    <Content components={{ Node, AsciiCanvas }} />
  </PostView>

  <div
    id="slug-categories-data"
    data-map={encodeURIComponent(JSON.stringify(slugCategoryMap))}
    hidden
  />
  <script is:inline type="module" src={postInlineTransitionsScript}></script>
</BaseLayout>
